# ============================================
# LLM (Language Model) Configuration
# ============================================

# Base URL for the LLM API service
# Example: http://localhost:3001/v1 (local service) or https://api.provider.com/v1 (remote)
LLM_BASE_URL=http://localhost:3001/v1

# API key for authentication with the LLM service
# Replace with your actual API key from the LLM provider
LLM_API_KEY=<freellmapi_key>

# Model name to use for LLM requests
# Examples: "auto", "gpt-4", "gpt-3.5-turbo", or any model supported by your provider
LLM_MODEL=auto

# ============================================
# Telegram Configuration
# ============================================

# Telegram bot token for sending notifications
# Get this from BotFather on Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=<telegram_bot_token>

# Telegram chat ID where bot notifications will be sent
# This is the ID of the chat (user or group) to receive messages
TELEGRAM_CHAT_ID=<telegram_chat_id>

# ============================================
# Job Automation Configuration
# ============================================

# Enable/disable automatic job scanning
# Values: true (enabled) or false (disabled)
AUTO_START=true

# Interval in MINUTES between automated job scans
# Example: 5 = 5 minutes, 60 = 1 hour
AUTO_INTERVAL=5

# Comma-separated keywords to filter job postings
# The automation will search for jobs matching these keywords
# Example: "devops,sre,mlops" or "python developer,java engineer"
AUTO_KEYWORD=devops sr,devops,desecopsvops,intermedio,devops semi senior,SRE,mlops

# Time-to-live (in minutes) for the "already notified" registry.
# A URL won't be re-notified until this many minutes have passed since
# the last notification for that URL. After that it can be notified again.
# Default: 1440 (24 hours)
NOTIFIED_TTL_MINUTES=1440

# Enable/disable periodic Telegram heartbeat (communication test).
# Values: true (enabled) or false (disabled)
# Default: false
TELEGRAM_HEARTBEAT_ENABLED=false

# Interval in MINUTES between Telegram heartbeat messages.
# Only used when TELEGRAM_HEARTBEAT_ENABLED=true
# Default: 15
TELEGRAM_HEARTBEAT_INTERVAL=15
