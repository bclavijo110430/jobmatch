---
import BackendBadge from '@/components/react/BackendBadge.jsx';
---

<header class="glass sticky top-0 z-30 flex h-16 items-center justify-between px-4 lg:px-6">
  <div class="flex items-center gap-3">
    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-jm-primary to-jm-primary-hover text-white lg:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
    </div>
    <div>
      <h1 class="text-base font-semibold text-jm-text-bright lg:text-lg">JobMatch</h1>
      <p class="hidden text-xs text-jm-text-muted sm:block">Búsqueda inteligente de empleo</p>
    </div>
  </div>

  <BackendBadge client:load />
</header>
